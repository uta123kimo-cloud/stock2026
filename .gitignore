# === Python 環境與快取 ===
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
env/
venv/
.env

# === Streamlit 相關 ===
.streamlit/

# === 數據存儲策略 ===
# 1. 先排除所有 CSV 原始檔（節省 GitHub 空間，150 檔 CSV 太大且會被擋）
__pycache__/
.streamlit/
*.csv
# ✅ 放行數據資料夾與 JSON
!storage/
!storage/**/*.json

# 2. 確保資料夾結構被 Git 追蹤
!storage/
!storage/market/
!storage/v12/
!storage/v4/
!storage/regime/


