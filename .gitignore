import pandas as pd
import os

def save_raw_data_as_json(df_list, symbol_list):
    """
    將抓取到的 150 檔原始資料存為 JSON，確保能上傳至 GitHub
    """
    base_path = "storage/market"
    if not os.path.exists(base_path):
        os.makedirs(base_path)
    
    # 建議存成一個大檔案，避免 GitHub 檔案過多
    market_data = {}
    for df, symbol in zip(df_list, symbol_list):
        # 轉換為 dict 格式存儲
        market_data[symbol] = df.to_dict(orient='records')
    
    # 存成 JSON 格式
    import json
    with open(f"{base_path}/full_market_data.json", 'w', encoding='utf-8') as f:
        json.dump(market_data, f, ensure_ascii=False, indent=4)
    
    print(f"✅ 已將 150 檔原始數據存至 {base_path}/full_market_data.json")
